# Frontend (Vite exposes these to browser)
VITE_SF_CLIENT_ID=your_consumer_key
VITE_SF_REDIRECT_URI=https://your-app.vercel.app/callback
VITE_SF_INSTANCE_URL=https://login.salesforce.com
VITE_BACKEND_URL=http://localhost:3001

# Backend / Serverless (server-side only, no VITE_ prefix)
SF_CLIENT_ID=your_consumer_key
SF_CLIENT_SECRET=your_consumer_secret
SF_REDIRECT_URI=https://your-app.vercel.app/callback
SF_INSTANCE_URL=https://login.salesforce.com

# NOTE: On Vercel, set BOTH sets of env vars in the dashboard.
# VITE_ vars are baked into the frontend build.
# SF_ vars (no prefix) are used by serverless functions at runtime.
